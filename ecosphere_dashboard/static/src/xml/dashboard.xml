<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ecosphere_dashboard.Dashboard" owl="1">
        <div class="eco-dashboard-container h-100 overflow-auto bg-light pb-5">
            
            <!-- Loading State -->
            <t t-if="state.isLoading">
                <div class="d-flex justify-content-center align-items-center h-100">
                    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </t>

            <!-- Main Content -->
            <t t-else="">
                <div class="eco-dashboard-header p-4 bg-white border-bottom mb-4 shadow-sm">
                    <div class="container-fluid">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h1 class="font-weight-bold mb-1 text-dark" style="font-size: 28px;">Executive ESG Dashboard</h1>
                                <p class="text-muted mb-0">Real-time overview of organizational sustainability metrics.</p>
                            </div>
                            <div class="col-md-4 text-end">
                                <div class="eco-overall-score-pill d-inline-flex align-items-center bg-light border rounded-pill px-4 py-2">
                                    <span class="text-uppercase font-weight-bold text-muted mr-3" style="font-size:12px; letter-spacing:1px;">Overall ESG Score</span>
                                    <span class="font-weight-bolder text-primary" style="font-size:24px;"><t t-esc="state.data.scores.overall"/> / 100</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="container-fluid px-4">
                    
                    <!-- Top Scorecards -->
                    <div class="row mb-4">
                        <!-- Environment -->
                        <div class="col-md-4">
                            <div class="eco-scorecard card border-0 shadow-sm h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="eco-icon-wrapper bg-success-light text-success rounded-circle d-flex align-items-center justify-content-center" style="width:48px; height:48px;">
                                            <i class="fa fa-leaf fa-lg"></i>
                                        </div>
                                        <span class="badge bg-success-light text-success px-2 py-1">+2.4%</span>
                                    </div>
                                    <h5 class="text-muted text-uppercase mb-1" style="font-size:12px; font-weight:700; letter-spacing:0.5px;">Environmental</h5>
                                    <h2 class="font-weight-bold text-dark mb-0"><t t-esc="state.data.scores.env"/> <span class="text-muted" style="font-size:14px; font-weight:500;">/ 100</span></h2>
                                </div>
                            </div>
                        </div>

                        <!-- Social -->
                        <div class="col-md-4">
                            <div class="eco-scorecard card border-0 shadow-sm h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="eco-icon-wrapper bg-primary-light text-primary rounded-circle d-flex align-items-center justify-content-center" style="width:48px; height:48px;">
                                            <i class="fa fa-users fa-lg"></i>
                                        </div>
                                        <span class="badge bg-primary-light text-primary px-2 py-1">+1.1%</span>
                                    </div>
                                    <h5 class="text-muted text-uppercase mb-1" style="font-size:12px; font-weight:700; letter-spacing:0.5px;">Social Responsibility</h5>
                                    <h2 class="font-weight-bold text-dark mb-0"><t t-esc="state.data.scores.soc"/> <span class="text-muted" style="font-size:14px; font-weight:500;">/ 100</span></h2>
                                </div>
                            </div>
                        </div>

                        <!-- Governance -->
                        <div class="col-md-4">
                            <div class="eco-scorecard card border-0 shadow-sm h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="eco-icon-wrapper bg-purple-light text-purple rounded-circle d-flex align-items-center justify-content-center" style="width:48px; height:48px;">
                                            <i class="fa fa-balance-scale fa-lg"></i>
                                        </div>
                                        <span class="badge bg-danger-light text-danger px-2 py-1">-0.5%</span>
                                    </div>
                                    <h5 class="text-muted text-uppercase mb-1" style="font-size:12px; font-weight:700; letter-spacing:0.5px;">Governance &amp; Ethics</h5>
                                    <h2 class="font-weight-bold text-dark mb-0"><t t-esc="state.data.scores.gov"/> <span class="text-muted" style="font-size:14px; font-weight:500;">/ 100</span></h2>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Main Content Area -->
                    <div class="row">
                        
                        <!-- Left Column: Chart -->
                        <div class="col-xl-8 mb-4">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                                    <h4 class="font-weight-bold text-dark mb-0" style="font-size: 16px;">ESG Trend Analysis (6 Months)</h4>
                                </div>
                                <div class="card-body px-4 pb-4 pt-3">
                                    <div style="height: 350px; position: relative;">
                                        <canvas t-ref="chartCanvas"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column: Leaderboard & Alerts -->
                        <div class="col-xl-4 mb-4">
                            
                            <!-- Alerts -->
                            <t t-if="state.data.alerts.length > 0">
                                <div class="card border-0 shadow-sm mb-4 bg-danger-light border-danger">
                                    <div class="card-body p-3">
                                        <h6 class="text-danger font-weight-bold mb-3"><i class="fa fa-bell-o mr-2"></i> Action Required</h6>
                                        <ul class="list-unstyled mb-0">
                                            <t t-foreach="state.data.alerts" t-as="alert" t-key="alert.title">
                                                <li class="mb-2 pb-2 border-bottom border-danger-light last-no-border">
                                                    <div class="d-flex w-100 justify-content-between">
                                                        <span class="text-dark font-weight-semibold" style="font-size:13px;"><t t-esc="alert.title"/></span>
                                                    </div>
                                                    <small class="text-danger"><t t-esc="alert.date"/></small>
                                                </li>
                                            </t>
                                        </ul>
                                    </div>
                                </div>
                            </t>

                            <!-- Leaderboard -->
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-white border-bottom pt-4 pb-3 px-4">
                                    <h4 class="font-weight-bold text-dark mb-0" style="font-size: 16px;">Top Departments</h4>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover table-borderless mb-0 eco-leaderboard-table">
                                            <thead class="bg-light text-muted">
                                                <tr>
                                                    <th class="font-weight-semibold" style="font-size: 12px; padding: 12px 24px;">DEPARTMENT</th>
                                                    <th class="font-weight-semibold text-end" style="font-size: 12px; padding: 12px 24px;">SCORE</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="state.data.leaderboard" t-as="dept" t-key="dept.id">
                                                    <tr class="cursor-pointer" t-on-click="() => this.openDepartment(dept.id)">
                                                        <td style="padding: 16px 24px;">
                                                            <div class="font-weight-bold text-dark" style="font-size:14px;"><t t-esc="dept.name"/></div>
                                                            <div class="text-muted" style="font-size:11px;">
                                                                E: <t t-esc="dept.env"/> | S: <t t-esc="dept.soc"/> | G: <t t-esc="dept.gov"/>
                                                            </div>
                                                        </td>
                                                        <td class="text-end align-middle" style="padding: 16px 24px;">
                                                            <span class="badge bg-primary rounded-pill px-3 py-2" style="font-size:14px;">
                                                                <t t-esc="dept.score"/>
                                                            </span>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </t>
        </div>
    </t>

</templates>
