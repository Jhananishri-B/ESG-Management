<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module Category -->
        <record id="module_category_ecosphere" model="ir.module.category">
            <field name="name">EcoSphere ESG Management</field>
            <field name="description">Helps manage Environmental, Social, and Governance compliance.</field>
            <field name="sequence">10</field>
        </record>

        <!-- User Groups -->
        <record id="group_ecosphere_employee" model="res.groups">
            <field name="name">Employee</field>
            <field name="category_id" ref="module_category_ecosphere"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_ecosphere_manager" model="res.groups">
            <field name="name">ESG Manager</field>
            <field name="category_id" ref="module_category_ecosphere"/>
            <field name="implied_ids" eval="[(4, ref('group_ecosphere_employee'))]"/>
        </record>

        <record id="group_ecosphere_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_ecosphere"/>
            <field name="implied_ids" eval="[(4, ref('group_ecosphere_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
