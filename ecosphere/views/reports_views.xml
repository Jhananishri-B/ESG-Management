<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ESG Report Configuration Views -->
    <record id="view_esg_report_config_list" model="ir.ui.view">
        <field name="name">esg.report.config.list</field>
        <field name="model">esg.report.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="id"/>
            </list>
        </field>
    </record>

    <record id="view_esg_report_config_form" model="ir.ui.view">
        <field name="name">esg.report.config.form</field>
        <field name="model">esg.report.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_esg_report_config_search" model="ir.ui.view">
        <field name="name">esg.report.config.search</field>
        <field name="model">esg.report.config</field>
        <field name="arch" type="xml">
            <search>
                <field name="id"/>
            </search>
        </field>
    </record>

    <record id="action_esg_report_config" model="ir.actions.act_window">
        <field name="name">ESG Reports</field>
        <field name="res_model">esg.report.config</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esg_report_config_search"/>
    </record>
</odoo>
