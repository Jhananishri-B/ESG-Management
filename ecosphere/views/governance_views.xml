<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ESG Policy Views -->
    <record id="view_esg_policy_list" model="ir.ui.view">
        <field name="name">esg.policy.list</field>
        <field name="model">esg.policy</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="version"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_esg_policy_form" model="ir.ui.view">
        <field name="name">esg.policy.form</field>
        <field name="model">esg.policy</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Information Security Policy"/></h1>
                    </div>
                    <group>
                        <field name="version"/>
                    </group>
                    <group>
                        <field name="description" placeholder="Write policy text here..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_policy" model="ir.actions.act_window">
        <field name="name">Policies</field>
        <field name="res_model">esg.policy</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ESG Policy Acknowledgement Views -->
    <record id="view_esg_policy_acknowledgement_list" model="ir.ui.view">
        <field name="name">esg.policy.acknowledgement.list</field>
        <field name="model">esg.policy.acknowledgement</field>
        <field name="arch" type="xml">
            <list>
                <field name="policy_id"/>
                <field name="employee_id"/>
                <field name="acknowledgement_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_esg_policy_acknowledgement_form" model="ir.ui.view">
        <field name="name">esg.policy.acknowledgement.form</field>
        <field name="model">esg.policy.acknowledgement</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="draft,acknowledged"/>
                </header>
                <sheet>
                    <group>
                        <field name="policy_id"/>
                        <field name="employee_id"/>
                        <field name="acknowledgement_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_policy_acknowledgement" model="ir.actions.act_window">
        <field name="name">Policy Acknowledgements</field>
        <field name="res_model">esg.policy.acknowledgement</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ESG Audit Views -->
    <record id="view_esg_audit_list" model="ir.ui.view">
        <field name="name">esg.audit.list</field>
        <field name="model">esg.audit</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="auditor_id"/>
                <field name="date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_esg_audit_form" model="ir.ui.view">
        <field name="name">esg.audit.form</field>
        <field name="model">esg.audit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="draft,completed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Q3 Security Audit"/></h1>
                    </div>
                    <group>
                        <field name="auditor_id"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_audit" model="ir.actions.act_window">
        <field name="name">Audits</field>
        <field name="res_model">esg.audit</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ESG Compliance Issue Views -->
    <record id="view_esg_compliance_issue_list" model="ir.ui.view">
        <field name="name">esg.compliance.issue.list</field>
        <field name="model">esg.compliance.issue</field>
        <field name="arch" type="xml">
            <list>
                <field name="audit_id"/>
                <field name="severity"/>
                <field name="owner_id"/>
                <field name="due_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_esg_compliance_issue_form" model="ir.ui.view">
        <field name="name">esg.compliance.issue.form</field>
        <field name="model">esg.compliance.issue</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="open,in_progress,resolved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="audit_id"/>
                            <field name="severity"/>
                        </group>
                        <group>
                            <field name="owner_id"/>
                            <field name="due_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Describe the compliance issue..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_compliance_issue" model="ir.actions.act_window">
        <field name="name">Compliance Issues</field>
        <field name="res_model">esg.compliance.issue</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
