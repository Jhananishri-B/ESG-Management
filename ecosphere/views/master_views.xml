<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ESG Department Views -->
    <record id="view_esg_department_list" model="ir.ui.view">
        <field name="name">esg.department.list</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="head_id"/>
                <field name="parent_id"/>
                <field name="employee_count"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_esg_department_form" model="ir.ui.view">
        <field name="name">esg.department.form</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,inactive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Research &amp; Development"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="head_id"/>
                        </group>
                        <group>
                            <field name="parent_id"/>
                            <field name="employee_count"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_esg_department_search" model="ir.ui.view">
        <field name="name">esg.department.search</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Active" name="active" domain="[('status', '=', 'active')]"/>
            </search>
        </field>
    </record>

    <record id="action_esg_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">esg.department</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esg_department_search"/>
    </record>

    <!-- ESG Category Views -->
    <record id="view_esg_category_list" model="ir.ui.view">
        <field name="name">esg.category.list</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_esg_category_form" model="ir.ui.view">
        <field name="name">esg.category.form</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="type"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">esg.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ESG Emission Factor Views -->
    <record id="view_esg_emission_factor_list" model="ir.ui.view">
