<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dashboard_frontend" name="EcoSphere Frontend Dashboard">
        <t t-call="website.layout">
            <style>
                /* Premium Dark Mode Styling */
                body {
                    background-color: #0d0f14 !important;
                    color: #e2e8f0 !important;
                    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
                }
                
                #wrapwrap {
                    background-color: #0d0f14 !important;
                }

                .esg-container {
                    background-color: #0d0f14;
                    min-height: 100vh;
                    display: flex;
                }

                /* Sidebar */
                .esg-sidebar {
                    width: 260px;
                    background: rgba(18, 22, 31, 0.9);
                    border-right: 1px solid rgba(255, 255, 255, 0.08);
                    padding: 24px;
                    display: flex;
                    flex-direction: column;
                    gap: 30px;
                }

                .esg-sidebar-brand {
                    font-size: 1.25rem;
                    font-weight: 700;
                    color: #3b82f6;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

                .esg-nav-list {
                    list-style: none;
                    padding: 0;
                    margin: 0;
                    display: flex;
                    flex-direction: column;
                    gap: 8px;
                }

                .esg-nav-link {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    border-radius: 8px;
                    color: #94a3b8;
                    text-decoration: none !important;
                    font-weight: 500;
                    transition: all 0.2s ease;
                    cursor: pointer;
                }

                .esg-nav-link:hover, .esg-nav-link.active {
                    color: #ffffff;
                    background: rgba(255, 255, 255, 0.05);
                    box-shadow: inset 4px 0 0 #3b82f6;
                }

                /* Content Area */
                .esg-content {
                    flex: 1;
                    padding: 40px;
                    overflow-y: auto;
                }

                /* Cards */
                .esg-glass-card {
                    background: rgba(22, 28, 41, 0.6);
                    backdrop-filter: blur(12px);
                    -webkit-backdrop-filter: blur(12px);
                    border: 1px solid rgba(255, 255, 255, 0.08);
                    border-radius: 16px;
                    padding: 24px;
                    margin-bottom: 24px;
                    transition: transform 0.2s ease;
                }

                .esg-glass-card:hover {
                    transform: translateY(-2px);
                }

                /* Score Badges */
                .score-card {
                    display: flex;
                    flex-direction: column;
                    justify-content: space-between;
                    height: 120px;
                }

                .score-value {
                    font-size: 2rem;
                    font-weight: 800;
                }

                .score-green { border-left: 4px solid #10b981; }
                .score-blue { border-left: 4px solid #3b82f6; }
                .score-purple { border-left: 4px solid #8b5cf6; }
                .score-indigo { border-left: 4px solid #6366f1; }

                /* Tables */
                .esg-table {
                    width: 100%;
                    border-collapse: collapse;
                    color: #e2e8f0;
                }

                .esg-table th {
                    text-align: left;
                    padding: 12px 16px;
                    background: rgba(255, 255, 255, 0.03);
                    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                    color: #94a3b8;
                    font-weight: 600;
                }

                .esg-table td {
                    padding: 16px;
                    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                }

                /* Form Controls */
                .esg-input {
                    background: rgba(255, 255, 255, 0.05);
                    border: 1px solid rgba(255, 255, 255, 0.1);
                    border-radius: 8px;
                    color: #ffffff;
                    padding: 10px 16px;
                    width: 100%;
                }

                .esg-input:focus {
                    background: rgba(255, 255, 255, 0.08);
                    border-color: #3b82f6;
                    outline: none;
                }

                .esg-btn {
                    background: #3b82f6;
                    color: #ffffff;
                    border: none;
                    border-radius: 8px;
                    padding: 10px 20px;
                    font-weight: 600;
                    cursor: pointer;
                    transition: background 0.2s ease;
                }

                .esg-btn:hover {
                    background: #2563eb;
                }

                .section-panel {
                    display: none;
                }
                .section-panel.active {
                    display: block;
                }
            </style>

            <div class="esg-container">
                <!-- Sidebar -->
                <div class="esg-sidebar">
                    <div class="esg-sidebar-brand">
                        <i class="fa fa-leaf"></i> EcoSphere
                    </div>
                    <ul class="esg-nav-list">
                        <li><a class="esg-nav-link active" data-target="dashboard"><i class="fa fa-th-large mr-2"></i> Dashboard</a></li>
                        <li><a class="esg-nav-link" data-target="environmental"><i class="fa fa-globe mr-2"></i> Environmental</a></li>
                        <li><a class="esg-nav-link" data-target="social"><i class="fa fa-users mr-2"></i> Social</a></li>
                        <li><a class="esg-nav-link" data-target="governance"><i class="fa fa-shield mr-2"></i> Governance</a></li>
                        <li><a class="esg-nav-link" data-target="gamification"><i class="fa fa-trophy mr-2"></i> Gamification</a></li>
                    </ul>
                </div>

                <!-- Main Content Area -->
                <div class="esg-content">
                    
                    <!-- ================= DASHBOARD PANEL ================= -->
                    <div id="dashboard" class="section-panel active">
                        <h2 class="mb-4">Dashboard: Executive Overview</h2>
                        <div class="row mb-4">
                            <!-- Cards -->
                            <div class="col-md-3">
                                <div class="esg-glass-card score-card score-green">
                                    <div class="text-muted">Environmental Score</div>
                                    <div class="score-value text-success"><t t-esc="environmental_score"/> <span class="font-size-sm" style="font-size: 1rem;">/ 100</span></div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="esg-glass-card score-card score-blue">
                                    <div class="text-muted">Social Score</div>
                                    <div class="score-value text-info"><t t-esc="social_score"/> <span class="font-size-sm" style="font-size: 1rem;">/ 100</span></div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="esg-glass-card score-card score-purple">
                                    <div class="text-muted">Governance Score</div>
                                    <div class="score-value text-warning"><t t-esc="governance_score"/> <span class="font-size-sm" style="font-size: 1rem;">/ 100</span></div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="esg-glass-card score-card score-indigo">
                                    <div class="text-muted">Overall ESG Score</div>
                                    <div class="score-value text-primary"><t t-esc="overall_score"/> <span class="font-size-sm" style="font-size: 1rem;">/ 100</span></div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-7">
                                <div class="esg-glass-card">
                                    <h4>Emission Trend (tCO₂e)</h4>
                                    <canvas id="trendChart" style="max-height: 250px;"></canvas>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="esg-glass-card">
                                    <h4>Department ESG Ranking</h4>
                                    <canvas id="rankingChart" style="max-height: 250px;"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================= ENVIRONMENTAL PANEL ================= -->
                    <div id="environmental" class="section-panel">
                        <h2 class="mb-4">Environmental: Emission Tracking &amp; Goals</h2>
                        
                        <div class="row">
                            <div class="col-md-8">
                                <div class="esg-glass-card">
                                    <h4>Environmental Goals</h4>
                                    <table class="esg-table">
                                        <thead>
                                            <tr>
                                                <th>Goal Name</th>
                                                <th>Target</th>
                                                <th>Current</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="environmental_goals" t-as="goal">
                                                <tr>
                                                    <td><t t-esc="goal.name"/></td>
                                                    <td><t t-esc="goal.target_value"/></td>
                                                    <td><t t-esc="goal.current_value"/></td>
                                                    <td>
                                                        <span class="badge badge-pill badge-primary"><t t-esc="goal.status"/></span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <div class="esg-glass-card">
                                    <h4>Log Carbon Data</h4>
                                    <form action="/ecosphere/carbon/log" method="post">
                                        <div class="form-group mb-3">
                                            <label>Transaction Name</label>
                                            <input type="text" name="name" class="esg-input" required="required" placeholder="e.g. Flight travel CO2"/>
                                        </div>
                                        <div class="form-group mb-3">
                                            <label>Quantity</label>
                                            <input type="number" step="any" name="quantity" class="esg-input" required="required"/>
                                        </div>
                                        <div class="form-group mb-3">
                                            <label>Department</label>
                                            <select name="department_id" class="esg-input" required="required">
                                                <t t-foreach="departments" t-as="dep">
                                                    <option t-att-value="dep.id"><t t-esc="dep.name"/></option>
                                                </t>
                                            </select>
                                        </div>
                                        <!-- Note: Simulating empty factor for prototype -->
                                        <input type="hidden" name="emission_factor_id" value="1"/>
                                        <button type="submit" class="esg-btn w-100 mt-2">Log Transaction</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================= SOCIAL PANEL ================= -->
                    <div id="social" class="section-panel">
                        <h2 class="mb-4" style="color: #f1f5f9; font-weight: 700;">Social: CSR &amp; Employee Engagement</h2>
                        <div class="row">
                            <t t-foreach="csr_activities" t-as="act">
                                <div class="col-md-4 mb-4">
                                    <div class="esg-glass-card h-100 d-flex flex-column justify-content-between" style="border-radius: 14px; background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255, 255, 255, 0.08); padding: 22px; transition: transform 0.2s, box-shadow 0.2s;">
                                        <div>
                                            <h4 style="color: #60a5fa; font-weight: 600; font-size: 1.2rem; margin-bottom: 12px;"><t t-esc="act.name"/></h4>
                                            <p style="color: #cbd5e1; font-size: 0.9rem; line-height: 1.5; margin-bottom: 20px;"><t t-esc="act.description"/></p>
                                        </div>
                                        <div class="mt-auto">
                                            <t t-if="act.id in joined_activities">
                                                <button class="esg-btn w-100 py-2" disabled="disabled" style="background-color: #475569; border: none; border-radius: 8px; color: #cbd5e1; cursor: not-allowed; font-weight: 500; font-size: 0.9rem;">✓ Joined</button>
                                            </t>
                                            <t t-else="">
                                                <form action="/ecosphere/activity/join" method="post">
                                                    <input type="hidden" name="activity_id" t-att-value="act.id"/>
                                                    <button type="submit" class="esg-btn w-100 py-2" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8); color: #ffffff; font-weight: 600; border: none; border-radius: 8px; font-size: 0.9rem; transition: filter 0.2s;">Join Activity</button>
                                                </form>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- ================= GOVERNANCE PANEL ================= -->
                    <div id="governance" class="section-panel">
                        <h2 class="mb-4">Governance: Policies, Audits &amp; Compliance</h2>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="esg-glass-card">
                                    <h4>Policies</h4>
                                    <ul class="list-group list-group-flush bg-transparent">
                                        <t t-foreach="policies" t-as="policy">
                                            <li class="list-group-item bg-transparent text-white border-secondary d-flex justify-content-between align-items-center">
                                                <span><t t-esc="policy.name"/> (<t t-esc="policy.code"/>)</span>
                                                <span class="badge badge-info"><t t-esc="policy.status"/></span>
                                            </li>
                                        </t>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="esg-glass-card">
                                    <h4>Recent Compliance Audits</h4>
                                    <table class="esg-table">
                                        <thead>
                                            <tr>
                                                <th>Audit</th>
                                                <th>Auditor</th>
                                                <th>Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="audits" t-as="audit">
                                                <tr>
                                                    <td><t t-esc="audit.name"/></td>
                                                    <td><t t-esc="audit.auditor_id.name"/></td>
                                                    <td><t t-esc="audit.date"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================= GAMIFICATION PANEL ================= -->
                    <!-- ================= GAMIFICATION PANEL ================= -->
                    <div id="gamification" class="section-panel" style="margin-bottom: 24px;">
                        <h2 class="mb-4">Gamification Dashboard</h2>
                        
                        <!-- Custom CSS styling for Gamification Dashboard -->
                        <style>
                            .esg-summary-card {
                                border-radius: 12px;
                                border: 1px solid rgba(255,255,255,0.06);
                                background: rgba(30, 41, 59, 0.4);
                                transform: translateY(0);
                                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                                min-height: 100px;
                            }
                            .esg-summary-card:hover {
                                transform: translateY(-4px);
                                background: rgba(30, 41, 59, 0.7);
                                border-color: rgba(255,255,255,0.15);
                                box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
                            }
                            .esg-glass-card-compact {
                                transform: translateY(0);
                                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                            }
                            .esg-glass-card-compact:hover {
                                transform: translateY(-4px);
                                background: rgba(30, 41, 59, 0.85) !important;
                                border-color: rgba(255,255,255,0.12) !important;
                                box-shadow: 0 12px 30px rgba(0,0,0,0.4);
                            }
                            .leaderboard-row:hover {
                                background: rgba(255,255,255,0.05) !important;
                            }
                            #gamification .text-muted {
                                color: #cbd5e1 !important;
                            }
                        </style>

                        <!-- Alerts/Notifications -->
                        <div t-if="success_message" class="alert alert-success alert-dismissible fade show mb-4" role="alert" style="background-color: rgba(16, 185, 129, 0.2); border: 1px solid #10b981; color: #e2e8f0; border-radius: 8px; padding: 12px 20px;">
                            <span t-esc="success_message"/>
                        </div>
                        <div t-if="warning_message" class="alert alert-warning alert-dismissible fade show mb-4" role="alert" style="background-color: rgba(245, 158, 11, 0.2); border: 1px solid #f59e0b; color: #e2e8f0; border-radius: 8px; padding: 12px 20px;">
                            <span t-esc="warning_message"/>
                        </div>
                        <div t-if="error_message" class="alert alert-danger alert-dismissible fade show mb-4" role="alert" style="background-color: rgba(239, 68, 68, 0.2); border: 1px solid #ef4444; color: #e2e8f0; border-radius: 8px; padding: 12px 20px;">
                            <span t-esc="error_message"/>
                        </div>

                        <!-- Dashboard UI Legends -->
                        <div class="mb-4 p-3" style="border-radius: 12px; background: rgba(30, 41, 59, 0.55); border: 1px solid rgba(255, 255, 255, 0.12); font-size: 0.8rem;">
                            <div class="row align-items-center">
                                <div class="col-12 col-md-3 mb-2 mb-md-0 text-light font-weight-bold uppercase" style="letter-spacing: 0.5px; font-size: 0.75rem; color: #cbd5e1;">
                                    <i class="fa fa-info-circle mr-1 text-info"></i> Dashboard Legend:
                                </div>
                                <div class="col-12 col-md-9">
                                    <div class="d-flex flex-wrap" style="gap: 15px;">
                                        <div class="d-flex align-items-center">
                                            <span class="text-warning mr-1" style="font-size: 0.95rem;" title="1st Place (Gold Champion Medal) / Total XP Earned">🏆 / <i class="fa fa-trophy"></i></span>
                                            <span class="text-sm" style="color: #cbd5e1;">Total XP Rank / 1st Place Champion</span>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <span class="text-light mr-1" style="font-size: 0.95rem;" title="Runner-up rankings">🥈 / 🥉</span>
                                            <span class="text-sm" style="color: #cbd5e1;">2nd &amp; 3rd Place Leaderboard Medals</span>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <span class="text-primary mr-1" style="font-size: 0.95rem;" title="Milestone Badges unlocked">🏅 / <i class="fa fa-certificate"></i></span>
                                            <span class="text-sm" style="color: #cbd5e1;">Earned Badges &amp; Milestone Medals</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Top Summary Cards -->
                        <div class="row mb-4">
                            <!-- Card 1: Total XP -->
                            <div class="col-md-3 col-sm-6 mb-3">
                                <div class="esg-summary-card p-3 h-100 d-flex align-items-center justify-content-between cursor-pointer">
                                    <div class="text-left">
                                        <div class="small uppercase font-weight-bold" style="letter-spacing: 0.5px; color: #e2e8f0;">Total XP</div>
                                        <h3 class="mb-0 text-warning" style="font-size: 1.8rem; font-weight: 700; margin-top: 4px;"><t t-esc="employee_total_xp"/></h3>
                                    </div>
                                    <div style="font-size: 2.3rem;" class="text-warning">
                                        <i class="fa fa-trophy"></i>
                                    </div>
                                </div>
                            </div>
                            <!-- Card 2: Challenges Joined -->
                            <div class="col-md-3 col-sm-6 mb-3">
                                <div class="esg-summary-card p-3 h-100 d-flex align-items-center justify-content-between cursor-pointer">
                                    <div class="text-left">
                                        <div class="small uppercase font-weight-bold" style="letter-spacing: 0.5px; color: #e2e8f0;">Challenges Joined</div>
                                        <h3 class="mb-0 text-info" style="font-size: 1.8rem; font-weight: 700; margin-top: 4px;"><t t-esc="employee_joined_challenges_count"/></h3>
                                    </div>
                                    <div style="font-size: 2.3rem;" class="text-info">
                                        <i class="fa fa-bullseye"></i>
                                    </div>
                                </div>
                            </div>
                            <!-- Card 3: Earned Badges -->
                            <div class="col-md-3 col-sm-6 mb-3">
                                <div class="esg-summary-card p-3 h-100 d-flex align-items-center justify-content-between cursor-pointer">
                                    <div class="text-left">
                                        <div class="small uppercase font-weight-bold" style="letter-spacing: 0.5px; color: #e2e8f0;">Earned Badges</div>
                                        <h3 class="mb-0 text-primary" style="font-size: 1.8rem; font-weight: 700; margin-top: 4px;"><t t-esc="employee_earned_badges_count"/></h3>
                                    </div>
                                    <div style="font-size: 2.3rem;" class="text-primary">
                                        <i class="fa fa-certificate"></i>
                                    </div>
                                </div>
                            </div>
                            <!-- Card 4: Rewards Redeemed -->
                            <div class="col-md-3 col-sm-6 mb-3">
                                <div class="esg-summary-card p-3 h-100 d-flex align-items-center justify-content-between cursor-pointer">
                                    <div class="text-left">
                                        <div class="small uppercase font-weight-bold" style="letter-spacing: 0.5px; color: #e2e8f0;">Rewards Redeemed</div>
                                        <h3 class="mb-0 text-success" style="font-size: 1.8rem; font-weight: 700; margin-top: 4px;"><t t-esc="employee_rewards_redeemed_count"/></h3>
                                    </div>
                                    <div style="font-size: 2.3rem;" class="text-success">
                                        <i class="fa fa-gift"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 1. Active Challenges Section -->
                        <h3 class="mb-3 text-warning">Active Challenges</h3>
                        <div class="row mb-4">
                            <t t-foreach="challenges" t-as="ch">
                                <div class="col-md-4 mb-4">
                                    <div class="esg-glass-card-compact h-100 p-3 d-flex flex-column justify-content-between" style="border-radius: 14px; background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255, 255, 255, 0.06); transition: transform 0.2s, box-shadow 0.2s; min-height: 250px; max-height: 380px;">
                                        <div>
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h4 class="text-warning mb-0" style="font-size: 1.1rem; font-weight: 600;"><t t-esc="ch.title"/></h4>
                                                <span class="badge badge-info text-capitalize" style="font-size: 0.75rem;"><t t-esc="ch.difficulty"/></span>
                                            </div>
                                            <p class="text-muted small mb-3" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;"><t t-esc="ch.description"/></p>
                                            
                                            <div class="d-flex flex-wrap mb-3" style="gap: 5px;">
                                                <span class="badge badge-success" style="font-size: 0.75rem;"><i class="fa fa-star mr-1"></i> <t t-esc="ch.xp"/> XP</span>
                                                <span class="badge badge-secondary text-capitalize" style="font-size: 0.75rem;" t-if="ch.category_id"><t t-esc="ch.category_id.name"/></span>
                                                <span class="badge text-light bg-dark" style="font-size: 0.75rem;" t-if="ch.deadline"><i class="fa fa-calendar mr-1"></i> <t t-esc="ch.deadline"/></span>
                                            </div>

                                            <!-- Progress Bar (if joined) -->
                                            <t t-if="ch.id in joined_challenges">
                                                <div class="mb-3">
                                                    <div class="d-flex justify-content-between small text-muted mb-1">
                                                        <span>Progress</span>
                                                        <span><t t-esc="int(challenge_progress.get(ch.id, 0.0))"/>%</span>
                                                    </div>
                                                    <div class="progress" style="height: 6px; background-color: rgba(255,255,255,0.1); border-radius: 3px;">
                                                        <div class="progress-bar bg-success" role="progressbar" t-attf-style="width: #{challenge_progress.get(ch.id, 0.0)}%; border-radius: 3px;"></div>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                        <div class="mt-2">
                                            <t t-if="ch.id in joined_challenges">
                                                <button class="esg-btn w-100 py-2" disabled="disabled" style="background-color: #475569; border: none; border-radius: 8px; color: #cbd5e1; cursor: not-allowed; font-weight: 500; font-size: 0.9rem;">✓ Joined</button>
                                            </t>
                                            <t t-else="">
                                                <form t-attf-action="/ecosphere/challenge/join/#{ch.id}" method="post">
                                                    <button type="submit" class="esg-btn w-100 py-2" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: #000; font-weight: 600; border: none; border-radius: 8px; font-size: 0.85rem; transition: filter 0.2s;">Join Challenge</button>
                                                </form>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <!-- 2. Earned Badges Section -->
                        <h3 class="mb-3 text-primary">Your Earned Badges</h3>
                        <div class="row mb-4">
                            <t t-if="not earned_badges">
                                <div class="col-12">
                                    <div class="esg-glass-card text-center p-4" style="border-radius: 14px; background: rgba(30, 41, 59, 0.2); border: 1px dashed rgba(255,255,255,0.1); color: #94a3b8;">
                                        <div class="mb-3 mt-1" style="font-size: 2.5rem; color: #475569;">
                                            <i class="fa fa-lock"></i>
                                        </div>
                                        <h4 class="mb-1" style="font-size: 1.1rem; font-weight: 600; color: #cbd5e1;">No badges earned yet.</h4>
                                        <p class="small mb-1 text-muted">Complete sustainability challenges or achieve high XP goals to unlock prestigious badges!</p>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <t t-foreach="earned_badges" t-as="badge">
                                    <div class="col-md-3 mb-4">
                                        <div class="esg-glass-card-compact text-center p-3 h-100 d-flex flex-column justify-content-between" style="border-radius: 14px; background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255, 255, 255, 0.06); transition: transform 0.2s, box-shadow 0.2s;">
                                            <div>
                                                <div class="mb-3 mx-auto mt-2">
                                                    <t t-if="badge.icon">
                                                        <img t-attf-src="data:image/png;base64,#{badge.icon}" style="height: 60px; width: 60px; object-fit: contain;" class="mx-auto rounded-circle"/>
                                                    </t>
                                                    <t t-else="">
                                                        <div class="mx-auto rounded-circle d-flex align-items-center justify-content-center bg-dark text-warning" style="height: 60px; width: 60px; font-size: 1.5rem; border: 2px solid rgba(245, 158, 11, 0.3);">
                                                            <i class="fa fa-certificate"></i>
                                                        </div>
                                                    </t>
                                                </div>
                                                <h4 class="text-primary mb-1" style="font-size: 1.05rem; font-weight: 600;"><t t-esc="badge.name"/></h4>
                                                <p class="text-muted small mb-2" style="line-height: 1.3;"><t t-esc="badge.description"/></p>
                                            </div>
                                            <div class="text-info small mt-2 pt-2 border-top" style="border-color: rgba(255,255,255,0.05); font-size: 0.75rem;">
                                                <i class="fa fa-key mr-1"></i> <t t-esc="badge.unlock_rule"/>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </t>
                        </div>

                        <!-- 3. Rewards Section -->
                        <h3 class="mb-3 text-success">Available Rewards</h3>
                        <div class="row mb-4">
                            <t t-foreach="rewards" t-as="rew">
                                <div class="col-md-4 mb-4">
                                    <div class="esg-glass-card-compact h-100 p-3 d-flex flex-column justify-content-between" style="border-radius: 14px; background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255, 255, 255, 0.06); transition: transform 0.2s, box-shadow 0.2s; min-height: 200px;">
                                        <div class="d-flex align-items-start" style="gap: 12px;">
                                            <div class="rounded p-2 text-success mr-2" style="background: rgba(16, 185, 129, 0.1); font-size: 1.6rem; border-radius: 10px; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fa fa-gift"></i>
                                            </div>
                                            <div class="flex-grow-1" style="overflow: hidden;">
                                                <h4 class="text-success mb-1" style="font-size: 1.1rem; font-weight: 600;"><t t-esc="rew.name"/></h4>
                                                <p class="text-muted small mb-2" style="line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><t t-esc="rew.description"/></p>
                                                <div class="d-flex mb-1" style="gap: 5px;">
                                                    <span class="badge badge-success" style="font-size: 0.75rem;"><t t-esc="rew.points_required"/> XP</span>
                                                    <span class="badge badge-info" style="font-size: 0.75rem;">Stock: <t t-esc="rew.stock"/></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mt-3">
                                            <t t-if="rew.stock &lt;= 0">
                                                <button class="esg-btn w-100 py-2" disabled="disabled" style="cursor: not-allowed; background-color: #475569; border: none; border-radius: 8px; color: #cbd5e1; font-weight: 500; font-size: 0.85rem;">Out of Stock</button>
                                            </t>
                                            <t t-else="">
                                                <form action="/ecosphere/reward/redeem" method="post">
                                                    <input type="hidden" name="reward_id" t-att-value="rew.id"/>
                                                    <button type="submit" class="esg-btn w-100 py-2" style="background: linear-gradient(135deg, #10b981, #059669); color: #000; font-weight: 600; border: none; border-radius: 8px; font-size: 0.85rem; transition: filter 0.2s;">Redeem Reward</button>
                                                </form>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <!-- 4. Leaderboard Section -->
                        <h3 class="mb-3 text-info">Leaderboard</h3>
                        <div class="esg-glass-card-compact p-3" style="border-radius: 14px; background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255, 255, 255, 0.06);">
                            <table class="esg-table" style="width: 100%; border-collapse: separate; border-spacing: 0 8px;">
                                <thead>
                                    <tr class="text-muted small" style="border-bottom: 2px solid rgba(255,255,255,0.05); text-align: left;">
                                        <th class="p-2" style="font-weight: 600;">Rank</th>
                                        <th class="p-2" style="font-weight: 600;">Employee Name</th>
                                        <th class="p-2" style="font-weight: 600; text-align: right;">XP</th>
                                        <th class="p-2" style="font-weight: 600; text-align: right;">Badges</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="leaderboard" t-as="row">
                                        <tr t-attf-class="leaderboard-row #{'d-none' if row_index &gt;= 5 else ''}" style="background: rgba(255,255,255,0.02); border-radius: 8px; transition: background 0.2s;">
                                            <td class="p-2" style="border-radius: 8px 0 0 8px; font-weight: bold; color: #a1a1aa;">
                                                <t t-if="row_index == 0"><span title="1st Place - Gold Medalist Champion">🏆 1</span></t>
                                                <t t-elif="row_index == 1"><span title="2nd Place - Silver Medalist">🥈 2</span></t>
                                                <t t-elif="row_index == 2"><span title="3rd Place - Bronze Medalist">🥉 3</span></t>
                                                <t t-else=""><span title="Runner-up Rank"><t t-esc="row_index + 1"/></span></t>
                                            </td>
                                            <td class="p-2" style="font-weight: 500; color: #e4e4e7;"><t t-esc="row['name']"/></td>
                                            <td class="p-2 text-warning" style="text-align: right; font-weight: bold;"><t t-esc="row['xp']"/> XP</td>
                                            <td class="p-2 text-primary" style="border-radius: 0 8px 8px 0; text-align: right; font-weight: bold;">
                                                <t t-esc="row['badge_count']"/> <i class="fa fa-certificate small" title="Milestone Badges Earned"></i>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                            <t t-if="len(leaderboard) &gt; 5">
                                <div class="text-center mt-3">
                                    <button id="btn-toggle-leaderboard" class="btn btn-outline-info" style="font-size: 0.85rem; border-radius: 20px; padding: 6px 20px; transition: background 0.2s;" onclick="toggleLeaderboard()">
                                        View All
                                    </button>
                                </div>
                            </t>
                        </div>

                        <!-- Leaderboard Script -->
                        <script type="text/javascript">
                            function toggleLeaderboard() {
                                var btn = document.getElementById('btn-toggle-leaderboard');
                                var rows = document.querySelectorAll('.leaderboard-row');
                                var isExpanded = btn.innerHTML.trim() === 'Show Less';
                                
                                for (var i = 5; i &lt; rows.length; i++) {
                                    if (isExpanded) {
                                        rows[i].classList.add('d-none');
                                    } else {
                                        rows[i].classList.remove('d-none');
                                    }
                                }
                                btn.innerHTML = isExpanded ? 'View All' : 'Show Less';
                            }
                        </script>
                    </div>

                </div>
            </div>

            <!-- Include ChartJS and JS Logic -->
            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    // Tab Switching
                    const navLinks = document.querySelectorAll('.esg-nav-link');
                    const panels = document.querySelectorAll('.section-panel');

                    navLinks.forEach(link => {
                        link.addEventListener('click', function(e) {
                            e.preventDefault();
                            navLinks.forEach(l => l.classList.remove('active'));
                            panels.forEach(p => p.classList.remove('active'));

                            this.classList.add('active');
                            const target = this.getAttribute('data-target');
                            document.getElementById(target).classList.add('active');
                        });
                    });

                    // Handle URL Hash Navigation
                    if (window.location.hash) {
                        const hash = window.location.hash.substring(1);
                        const targetLink = document.querySelector(`.esg-nav-link[data-target="${hash}"]`);
                        if (targetLink) {
                            targetLink.click();
                        }
                    }

                    // Render charts if elements are on page
                    const trendCtx = document.getElementById('trendChart');
                    if (trendCtx) {
                        new Chart(trendCtx, {
                            type: 'line',
                            data: {
                                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                                datasets: [{
                                    label: 'Scope 1 + 2 CO2 Emissions',
                                    data: [65, 59, 80, 81, 56, 40],
                                    fill: false,
                                    borderColor: '#10b981',
                                    tension: 0.1
                                }]
                            },
                            options: {
                                responsive: true,
                                plugins: {
                                    legend: { labels: { color: '#e2e8f0' } }
                                },
                                scales: {
                                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
                                    x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } }
                                }
                            }
                        });
                    }

                    const rankingCtx = document.getElementById('rankingChart');
                    if (rankingCtx) {
                        new Chart(rankingCtx, {
                            type: 'bar',
                            data: {
                                labels: ['Sales', 'R&amp;D', 'Logistics', 'Marketing', 'Finance'],
                                datasets: [{
                                    label: 'ESG Points',
                                    data: [120, 150, 80, 95, 110],
                                    backgroundColor: 'rgba(59, 130, 246, 0.8)',
                                }]
                            },
                            options: {
                                responsive: true,
                                plugins: {
                                    legend: { labels: { color: '#e2e8f0' } }
                                },
                                scales: {
                                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
                                    x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } }
                                }
                            }
                        });
                    }
                });
            </script>
        </t>
    </template>
</odoo>
