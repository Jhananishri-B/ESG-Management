<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dashboard_frontend" name="EcoSphere Frontend Dashboard">
        <t t-call="website.layout">
            <style>
                /* Premium Dark Mode Styling */
                body {
                    background-color: #0d0f14 !important;
                    color: #e2e8f0 !important;
                    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
                }
                
                #wrapwrap {
                    background-color: #0d0f14 !important;
                }

                .esg-container {
                    background-color: #0d0f14;
                    min-height: 100vh;
                    display: flex;
                }

                /* Sidebar */
                .esg-sidebar {
                    width: 260px;
                    background: rgba(18, 22, 31, 0.9);
                    border-right: 1px solid rgba(255, 255, 255, 0.08);
                    padding: 24px;
                    display: flex;
                    flex-direction: column;
                    gap: 30px;
                }

                .esg-sidebar-brand {
                    font-size: 1.25rem;
                    font-weight: 700;
                    color: #3b82f6;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

                .esg-nav-list {
                    list-style: none;
                    padding: 0;
                    margin: 0;
                    display: flex;
                    flex-direction: column;
                    gap: 8px;
                }

                .esg-nav-link {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    border-radius: 8px;
                    color: #94a3b8;
                    text-decoration: none !important;
                    font-weight: 500;
                    transition: all 0.2s ease;
                    cursor: pointer;
                }

                .esg-nav-link:hover, .esg-nav-link.active {
                    color: #ffffff;
                    background: rgba(255, 255, 255, 0.05);
                    box-shadow: inset 4px 0 0 #3b82f6;
                }

                /* Content Area */
                .esg-content {
                    flex: 1;
                    padding: 40px;
                    overflow-y: auto;
                }

                /* Cards */
                .esg-glass-card {
                    background: rgba(22, 28, 41, 0.6);
                    backdrop-filter: blur(12px);
                    -webkit-backdrop-filter: blur(12px);
                    border: 1px solid rgba(255, 255, 255, 0.08);
                    border-radius: 16px;
                    padding: 24px;
                    margin-bottom: 24px;
                    transition: transform 0.2s ease;
                }

                .esg-glass-card:hover {
                    transform: translateY(-2px);
                }

                /* Score Badges */
                .score-card {
                    display: flex;
                    flex-direction: column;
                    justify-content: space-between;
                    height: 120px;
                }

                .score-value {
                    font-size: 2rem;
                    font-weight: 800;
                }

                .score-green { border-left: 4px solid #10b981; }
                .score-blue { border-left: 4px solid #3b82f6; }
                .score-purple { border-left: 4px solid #8b5cf6; }
                .score-indigo { border-left: 4px solid #6366f1; }

                /* Tables */
                .esg-table {
                    width: 100%;
                    border-collapse: collapse;
                    color: #e2e8f0;
                }

                .esg-table th {
                    text-align: left;
                    padding: 12px 16px;
                    background: rgba(255, 255, 255, 0.03);
                    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                    color: #94a3b8;
                    font-weight: 600;
                }

                .esg-table td {
                    padding: 16px;
                    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                }

                /* Form Controls */
                .esg-input {
                    background: rgba(255, 255, 255, 0.05);
                    border: 1px solid rgba(255, 255, 255, 0.1);
                    border-radius: 8px;
                    color: #ffffff;
                    padding: 10px 16px;
                    width: 100%;
                }

                .esg-input:focus {
                    background: rgba(255, 255, 255, 0.08);
                    border-color: #3b82f6;
                    outline: none;
                }

                .esg-btn {
                    background: #3b82f6;
                    color: #ffffff;
                    border: none;
                    border-radius: 8px;
                    padding: 10px 20px;
                    font-weight: 600;
                    cursor: pointer;
                    transition: background 0.2s ease;
                }

                .esg-btn:hover {
                    background: #2563eb;
                }

                .section-panel {
                    display: none;
                }
                .section-panel.active {
                    display: block;
                }
            </style>

            <div class="esg-container">
                <!-- Sidebar -->
                <div class="esg-sidebar">
                    <div class="esg-sidebar-brand">
                        <i class="fa fa-leaf"></i> EcoSphere
                    </div>
                    <ul class="esg-nav-list">
                        <li><a class="esg-nav-link active" data-target="dashboard"><i class="fa fa-th-large mr-2"></i> Dashboard</a></li>
                        <li><a class="esg-nav-link" data-target="environmental"><i class="fa fa-globe mr-2"></i> Environmental</a></li>
                        <li><a class="esg-nav-link" data-target="social"><i class="fa fa-users mr-2"></i> Social</a></li>
                        <li><a class="esg-nav-link" data-target="governance"><i class="fa fa-shield mr-2"></i> Governance</a></li>
                        <li><a class="esg-nav-link" data-target="gamification"><i class="fa fa-trophy mr-2"></i> Gamification</a></li>
                    </ul>
                </div>

                <!-- Main Content Area -->
                <div class="esg-content">
                    
                    <!-- ================= DASHBOARD PANEL ================= -->
                    <div id="dashboard" class="section-panel active">
                        <h2 class="mb-4">Dashboard: Executive Overview</h2>
                        <div class="row mb-4">
                            <!-- Cards -->
                            <div class="col-md-3">
                                <div class="esg-glass-card score-card score-green">
                                    <div class="text-muted">Environmental Score</div>
                                    <div class="score-value text-success">87 <span class="font-size-sm" style="font-size: 1rem;">/ 100</span></div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="esg-glass-card score-card score-blue">
                                    <div class="text-muted">Social Score</div>
                                    <div class="score-value text-info">74 <span class="font-size-sm" style="font-size: 1rem;">/ 100</span></div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="esg-glass-card score-card score-purple">
                                    <div class="text-muted">Governance Score</div>
                                    <div class="score-value text-warning">85 <span class="font-size-sm" style="font-size: 1rem;">/ 100</span></div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="esg-glass-card score-card score-indigo">
                                    <div class="text-muted">Overall ESG Score</div>
                                    <div class="score-value text-primary">81 <span class="font-size-sm" style="font-size: 1rem;">/ 100</span></div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-7">
                                <div class="esg-glass-card">
                                    <h4>Emission Trend (tCO₂e)</h4>
                                    <canvas id="trendChart" style="max-height: 250px;"></canvas>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="esg-glass-card">
                                    <h4>Department ESG Ranking</h4>
                                    <canvas id="rankingChart" style="max-height: 250px;"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================= ENVIRONMENTAL PANEL ================= -->
                    <div id="environmental" class="section-panel">
                        <h2 class="mb-4">Environmental: Emission Tracking &amp; Goals</h2>
                        
                        <div class="row">
                            <div class="col-md-8">
                                <div class="esg-glass-card">
                                    <h4>Environmental Goals</h4>
                                    <table class="esg-table">
                                        <thead>
                                            <tr>
                                                <th>Goal Name</th>
                                                <th>Target</th>
                                                <th>Current</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="environmental_goals" t-as="goal">
                                                <tr>
                                                    <td><t t-esc="goal.name"/></td>
                                                    <td><t t-esc="goal.target_value"/></td>
                                                    <td><t t-esc="goal.current_value"/></td>
                                                    <td>
                                                        <span class="badge badge-pill badge-primary"><t t-esc="goal.status"/></span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <div class="esg-glass-card">
                                    <h4>Log Carbon Data</h4>
                                    <form action="/ecosphere/carbon/log" method="post">
                                        <div class="form-group mb-3">
                                            <label>Transaction Name</label>
                                            <input type="text" name="name" class="esg-input" required="required" placeholder="e.g. Flight travel CO2"/>
                                        </div>
                                        <div class="form-group mb-3">
                                            <label>Quantity</label>
                                            <input type="number" step="any" name="quantity" class="esg-input" required="required"/>
                                        </div>
                                        <div class="form-group mb-3">
                                            <label>Department</label>
                                            <select name="department_id" class="esg-input" required="required">
                                                <t t-foreach="departments" t-as="dep">
                                                    <option t-att-value="dep.id"><t t-esc="dep.name"/></option>
                                                </t>
                                            </select>
                                        </div>
                                        <!-- Note: Simulating empty factor for prototype -->
                                        <input type="hidden" name="emission_factor_id" value="1"/>
                                        <button type="submit" class="esg-btn w-100 mt-2">Log Transaction</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================= SOCIAL PANEL ================= -->
                    <div id="social" class="section-panel">
                        <h2 class="mb-4">Social: CSR &amp; Employee Engagement</h2>
                        <div class="row">
                            <t t-foreach="csr_activities" t-as="act">
                                <div class="col-md-4 mb-4">
                                    <div class="esg-glass-card h-100 d-flex flex-column justify-content-between">
                                        <div>
                                            <h4 class="text-primary"><t t-esc="act.name"/></h4>
                                            <p class="text-muted"><t t-esc="act.description"/></p>
                                        </div>
                                        <form action="/ecosphere/activity/join" method="post" class="mt-3">
                                            <input type="hidden" name="activity_id" t-att-value="act.id"/>
                                            <button type="submit" class="esg-btn w-100">Join Activity</button>
                                        </form>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- ================= GOVERNANCE PANEL ================= -->
                    <div id="governance" class="section-panel">
                        <h2 class="mb-4">Governance: Policies, Audits &amp; Compliance</h2>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="esg-glass-card">
                                    <h4>Policies</h4>
                                    <ul class="list-group list-group-flush bg-transparent">
                                        <t t-foreach="policies" t-as="policy">
                                            <li class="list-group-item bg-transparent text-white border-secondary d-flex justify-content-between align-items-center">
                                                <span><t t-esc="policy.name"/> (<t t-esc="policy.code"/>)</span>
                                                <span class="badge badge-info"><t t-esc="policy.status"/></span>
                                            </li>
                                        </t>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="esg-glass-card">
                                    <h4>Recent Compliance Audits</h4>
                                    <table class="esg-table">
                                        <thead>
                                            <tr>
                                                <th>Audit</th>
                                                <th>Auditor</th>
                                                <th>Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="audits" t-as="audit">
                                                <tr>
                                                    <td><t t-esc="audit.name"/></td>
                                                    <td><t t-esc="audit.auditor"/></td>
                                                    <td><t t-esc="audit.audit_date"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================= GAMIFICATION PANEL ================= -->
                    <div id="gamification" class="section-panel">
                        <h2 class="mb-4">Gamification: Challenges &amp; Badges</h2>
                        <div class="row mb-4">
                            <t t-foreach="challenges" t-as="ch">
                                <div class="col-md-4 mb-4">
                                    <div class="esg-glass-card h-100 d-flex flex-column justify-content-between">
                                        <div>
                                            <h4 class="text-warning"><t t-esc="ch.title"/></h4>
                                            <p class="text-muted"><t t-esc="ch.description"/></p>
                                            <div class="mt-2"><span class="badge badge-warning"><t t-esc="ch.xp"/> XP</span></div>
                                        </div>
                                        <form action="/ecosphere/challenge/join" method="post" class="mt-3">
                                            <input type="hidden" name="challenge_id" t-att-value="ch.id"/>
                                            <button type="submit" class="esg-btn w-100">Join Challenge</button>
                                        </form>
                                    </div>
                                </div>
                            </t>
                        </div>
                        <div class="esg-glass-card">
                            <h4>Leaderboard</h4>
                            <table class="esg-table">
                                <thead>
                                    <tr>
                                        <th>Rank</th>
                                        <th>Employee</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="users" t-as="user">
                                        <tr>
                                            <td><t t-esc="user_index + 1"/></td>
                                            <td><t t-esc="user.name"/></td>
                                            <td>Active</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Include ChartJS and JS Logic -->
            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    // Tab Switching
                    const navLinks = document.querySelectorAll('.esg-nav-link');
                    const panels = document.querySelectorAll('.section-panel');

                    navLinks.forEach(link => {
                        link.addEventListener('click', function(e) {
                            e.preventDefault();
                            navLinks.forEach(l => l.classList.remove('active'));
                            panels.forEach(p => p.classList.remove('active'));

                            this.classList.add('active');
                            const target = this.getAttribute('data-target');
                            document.getElementById(target).classList.add('active');
                        });
                    });

                    // Handle URL Hash Navigation
                    if (window.location.hash) {
                        const hash = window.location.hash.substring(1);
                        const targetLink = document.querySelector(`.esg-nav-link[data-target="${hash}"]`);
                        if (targetLink) {
                            targetLink.click();
                        }
                    }

                    // Render charts if elements are on page
                    const trendCtx = document.getElementById('trendChart');
                    if (trendCtx) {
                        new Chart(trendCtx, {
                            type: 'line',
                            data: {
                                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                                datasets: [{
                                    label: 'Scope 1 + 2 CO2 Emissions',
                                    data: [65, 59, 80, 81, 56, 40],
                                    fill: false,
                                    borderColor: '#10b981',
                                    tension: 0.1
                                }]
                            },
                            options: {
                                responsive: true,
                                plugins: {
                                    legend: { labels: { color: '#e2e8f0' } }
                                },
                                scales: {
                                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
                                    x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } }
                                }
                            }
                        });
                    }

                    const rankingCtx = document.getElementById('rankingChart');
                    if (rankingCtx) {
                        new Chart(rankingCtx, {
                            type: 'bar',
                            data: {
                                labels: ['Sales', 'R&amp;D', 'Logistics', 'Marketing', 'Finance'],
                                datasets: [{
                                    label: 'ESG Points',
                                    data: [120, 150, 80, 95, 110],
                                    backgroundColor: 'rgba(59, 130, 246, 0.8)',
                                }]
                            },
                            options: {
                                responsive: true,
                                plugins: {
                                    legend: { labels: { color: '#e2e8f0' } }
                                },
                                scales: {
                                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
                                    x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } }
                                }
                            }
                        });
                    }
                });
            </script>
        </t>
    </template>
</odoo>
