<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ESG CSR Activity Views -->
    <record id="view_esg_csr_activity_list" model="ir.ui.view">
        <field name="name">esg.csr.activity.list</field>
        <field name="model">esg.csr.activity</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category_id"/>
                <field name="date"/>
                <field name="points"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_esg_csr_activity_form" model="ir.ui.view">
        <field name="name">esg.csr.activity.form</field>
        <field name="model">esg.csr.activity</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Tree Plantation Camp 2026"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="points"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Description of the CSR activity..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_csr_activity" model="ir.actions.act_window">
        <field name="name">CSR Activities</field>
        <field name="res_model">esg.csr.activity</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ESG Employee Participation Views -->
    <record id="view_esg_employee_participation_list" model="ir.ui.view">
        <field name="name">esg.employee.participation.list</field>
        <field name="model">esg.employee.participation</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="activity_id"/>
                <field name="points_earned"/>
                <field name="completion_date"/>
                <field name="approval_status"/>
            </list>
        </field>
    </record>

    <record id="view_esg_employee_participation_form" model="ir.ui.view">
        <field name="name">esg.employee.participation.form</field>
        <field name="model">esg.employee.participation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="approval_status" widget="statusbar" statusbar_visible="draft,under_review,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="activity_id"/>
                        </group>
                        <group>
                            <field name="points_earned"/>
                            <field name="completion_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="proof" widget="image" string="Upload Proof"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_employee_participation" model="ir.actions.act_window">
        <field name="name">Employee CSR Participations</field>
        <field name="res_model">esg.employee.participation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
