<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_diversity_metric_list" model="ir.ui.view">
            <field name="name">diversity.metric.list</field>
            <field name="model">diversity.metric</field>
            <field name="arch" type="xml">
                <list string="Diversity Metrics">
                    <field name="department_id"/>
                    <field name="period_display" string="Period"/>
                    <field name="total_employees"/>
                    <field name="female_count"/>
                    <field name="female_pct" string="Female %" widget="progressbar" options="{'editable': false}"/>
                    <field name="leadership_total"/>
                    <field name="female_leadership"/>
                    <field name="female_leadership_pct" string="Female Leadership %" widget="progressbar" options="{'editable': false}"/>
                    <field name="new_hires" string="New Hires"/>
                    <field name="attrition" string="Attrition"/>
                </list>
            </field>
        </record>

        <record id="view_diversity_metric_form" model="ir.ui.view">
            <field name="name">diversity.metric.form</field>
            <field name="model">diversity.metric</field>
            <field name="arch" type="xml">
                <form string="Diversity Metric">
                    <sheet>
                        <group>
                            <group>
                                <field name="department_id"/>
                                <field name="period_date"/>
                                <field name="period_display" readonly="1"/>
                            </group>
                        </group>
                        <group string="Headcount">
                            <group>
                                <field name="total_employees"/>
                                <field name="female_count"/>
                                <field name="male_count"/>
                                <field name="other_gender_count"/>
                                <field name="female_pct" readonly="1"/>
                            </group>
                            <group>
                                <field name="leadership_total"/>
                                <field name="female_leadership"/>
                                <field name="female_leadership_pct" readonly="1"/>
                            </group>
                        </group>
                        <group string="Age Distribution">
                            <field name="age_under_30" string="Under 30"/>
                            <field name="age_30_50" string="Age 30–50"/>
                            <field name="age_over_50" string="Over 50"/>
                        </group>
                        <group string="Movement">
                            <field name="new_hires"/>
                            <field name="attrition"/>
                        </group>
                        <group string="Notes">
                            <field name="notes" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_diversity_metric" model="ir.actions.act_window">
            <field name="name">Diversity Metrics</field>
            <field name="res_model">diversity.metric</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
