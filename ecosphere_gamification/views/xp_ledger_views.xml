<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_xp_ledger_list" model="ir.ui.view">
            <field name="name">xp.ledger.list</field>
            <field name="model">xp.ledger</field>
            <field name="arch" type="xml">
                <list string="XP Ledger" create="0" edit="0" delete="0">
                    <field name="date"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="amount" decoration-success="amount &gt; 0" decoration-danger="amount &lt; 0" widget="badge"/>
                    <field name="reason"/>
                    <field name="is_spendable" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="action_xp_ledger_employee" model="ir.actions.act_window">
            <field name="name">XP Ledger</field>
            <field name="res_model">xp.ledger</field>
            <field name="view_mode">list</field>
            <field name="domain">[('employee_id', '=', active_id)]</field>
        </record>
        
        <record id="action_xp_ledger_all" model="ir.actions.act_window">
            <field name="name">All XP Transactions</field>
            <field name="res_model">xp.ledger</field>
            <field name="view_mode">list</field>
        </record>
    </data>
</odoo>
