<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="action_report_esg_department" model="ir.actions.report">
        <field name="name">ESG Department Scorecard</field>
        <field name="model">esg.department</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ecosphere_reports.report_esg_department_template</field>
        <field name="report_file">ecosphere_reports.report_esg_department_template</field>
        <field name="print_report_name">'ESG Scorecard - %s' % (object.name)</field>
        <field name="binding_model_id" ref="ecosphere_core.model_esg_department"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="ecosphere_reports.paperformat_ecosphere_report"/>
    </record>

    <template id="report_esg_department_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        
                        <div class="row mt-4 mb-4 pb-3 border-bottom">
                            <div class="col-8">
                                <h1 style="color: #1e3a8a; font-weight: 800;"><t t-esc="doc.name"/></h1>
                                <h4 class="text-muted">ESG Department Scorecard</h4>
                            </div>
                            <div class="col-4 text-end">
                                <div style="background-color: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid #e2e8f0; display: inline-block;">
                                    <div style="font-size: 12px; color: #64748b; font-weight: bold; text-transform: uppercase;">Overall Score</div>
                                    <div style="font-size: 32px; font-weight: 900; color: #2563eb;">
                                        <t t-esc="doc.total_esg_score"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-5">
                            <div class="col-4">
                                <div style="border-left: 4px solid #10b981; padding-left: 15px; margin-bottom: 20px;">
                                    <h5 style="color: #10b981; font-weight: bold; margin-bottom: 5px;">Environmental</h5>
                                    <h2 style="margin: 0; font-weight: 800;"><t t-esc="doc.env_score"/></h2>
                                </div>
                            </div>
                            <div class="col-4">
                                <div style="border-left: 4px solid #3b82f6; padding-left: 15px; margin-bottom: 20px;">
                                    <h5 style="color: #3b82f6; font-weight: bold; margin-bottom: 5px;">Social</h5>
                                    <h2 style="margin: 0; font-weight: 800;"><t t-esc="doc.social_score"/></h2>
                                </div>
                            </div>
                            <div class="col-4">
                                <div style="border-left: 4px solid #8b5cf6; padding-left: 15px; margin-bottom: 20px;">
                                    <h5 style="color: #8b5cf6; font-weight: bold; margin-bottom: 5px;">Governance</h5>
                                    <h2 style="margin: 0; font-weight: 800;"><t t-esc="doc.governance_score"/></h2>
                                </div>
                            </div>
                        </div>

                        <h3 class="mb-3 border-bottom pb-2" style="color: #334155;">Department Details</h3>
                        <table class="table table-sm table-borderless">
                            <tbody>
                                <tr>
                                    <td style="width: 25%; font-weight: bold; color: #64748b;">Manager:</td>
                                    <td><t t-esc="doc.manager_id.name or 'N/A'"/></td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; color: #64748b;">Employees:</td>
                                    <td><t t-esc="doc.employee_count"/></td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; color: #64748b;">Parent Dept:</td>
                                    <td><t t-esc="doc.parent_id.name or 'None'"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-if="doc.goal_ids">
                            <h3 class="mt-5 mb-3 border-bottom pb-2" style="color: #334155;">Active ESG Goals</h3>
                            <table class="table table-striped table-sm">
                                <thead>
                                    <tr>
                                        <th>Goal Name</th>
                                        <th>Target Date</th>
                                        <th>Target Value</th>
                                        <th>Current</th>
                                        <th>Progress</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.goal_ids.filtered(lambda g: g.state == 'active')" t-as="goal">
                                        <td><t t-esc="goal.name"/></td>
                                        <td><t t-esc="goal.target_date"/></td>
                                        <td><t t-esc="goal.target_value"/> <t t-esc="goal.uom"/></td>
                                        <td><t t-esc="goal.current_value"/> <t t-esc="goal.uom"/></td>
                                        <td>
                                            <t t-esc="'%.1f' % goal.progress_pct"/>%
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
