<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ═══════════════════════════════════════════════════════════
             SECURITY GROUPS
        ═══════════════════════════════════════════════════════════ -->
        <record id="module_ecosphere" model="ir.module.category">
            <field name="name">EcoSphere ESG</field>
            <field name="description">ESG Management Platform</field>
            <field name="sequence">200</field>
        </record>

        <!-- Employee: read-only access to own department data -->
        <record id="group_ecosphere_employee" model="res.groups">
            <field name="name">ESG Employee</field>
            <field name="category_id" ref="module_ecosphere"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">
                Employees can view ESG information relevant to their department,
                join challenges, upload evidence, and track their own XP.
            </field>
        </record>

        <!-- Department Manager: manage own department -->
        <record id="group_ecosphere_dept_manager" model="res.groups">
            <field name="name">ESG Department Manager</field>
            <field name="category_id" ref="module_ecosphere"/>
            <field name="implied_ids" eval="[(4, ref('group_ecosphere_employee'))]"/>
            <field name="comment">
                Department Managers can approve CSR activities, challenge evidence,
                and view analytics for their own department.
            </field>
        </record>

        <!-- ESG Manager: full operational access -->
        <record id="group_ecosphere_manager" model="res.groups">
            <field name="name">ESG Manager</field>
            <field name="category_id" ref="module_ecosphere"/>
            <field name="implied_ids" eval="[(4, ref('group_ecosphere_dept_manager'))]"/>
            <field name="comment">
                ESG Managers have full operational access: create/edit all ESG
                records, run reports, manage policies and audits.
            </field>
        </record>

        <!-- Auditor: read-all + create audit records -->
        <record id="group_ecosphere_auditor" model="res.groups">
            <field name="name">ESG Auditor</field>
            <field name="category_id" ref="module_ecosphere"/>
            <field name="implied_ids" eval="[(4, ref('group_ecosphere_employee'))]"/>
            <field name="comment">
                Auditors have read access to all ESG data and can create/manage audits
                and compliance issues.
            </field>
        </record>

        <!-- Executive: read-all, executive dashboard -->
        <record id="group_ecosphere_executive" model="res.groups">
            <field name="name">ESG Executive</field>
            <field name="category_id" ref="module_ecosphere"/>
            <field name="implied_ids" eval="[(4, ref('group_ecosphere_employee'))]"/>
            <field name="comment">
                Executives have read-all access with a focused executive dashboard
                showing high-level KPIs and trend data.
            </field>
        </record>

        <!-- Administrator: unrestricted access + configuration -->
        <record id="group_ecosphere_admin" model="res.groups">
            <field name="name">ESG Administrator</field>
            <field name="category_id" ref="module_ecosphere"/>
            <field name="implied_ids" eval="[(4, ref('group_ecosphere_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="comment">
                Administrators have unrestricted access to all EcoSphere modules
                including system configuration, weight settings, and user management.
            </field>
        </record>

        <!-- ═══════════════════════════════════════════════════════════
             RECORD RULES
        ═══════════════════════════════════════════════════════════ -->

        <!-- ESG Goals: employees see only their department's goals -->
        <record id="rule_esg_goal_employee" model="ir.rule">
            <field name="name">ESG Goal: Employee sees own department</field>
            <field name="model_id" ref="ecosphere_core.model_esg_goal"/>
            <field name="domain_force">
                [('department_id.manager_id', '!=', False)]
            </field>
            <field name="groups" eval="[(4, ref('group_ecosphere_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ESG Goals: managers see all goals (no restriction) -->
        <record id="rule_esg_goal_manager" model="ir.rule">
            <field name="name">ESG Goal: Manager sees all</field>
            <field name="model_id" ref="ecosphere_core.model_esg_goal"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ecosphere_manager'))]"/>
        </record>

    </data>
</odoo>
