<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ════════════════════════════════════════════════════════════
             ESG CATEGORY VIEWS
        ════════════════════════════════════════════════════════════ -->
        <record id="view_esg_category_list" model="ir.ui.view">
            <field name="name">esg.category.list</field>
            <field name="model">esg.category</field>
            <field name="arch" type="xml">
                <list string="ESG Categories" editable="bottom" decoration-success="code == 'E'" decoration-info="code == 'S'" decoration-warning="code == 'G'">
                    <field name="sequence" widget="handle"/>
                    <field name="icon" widget="char"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="goal_count"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_esg_category_form" model="ir.ui.view">
            <field name="name">esg.category.form</field>
            <field name="model">esg.category</field>
            <field name="arch" type="xml">
                <form string="ESG Category">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Category Name"/>
                            <h1><field name="name" placeholder="e.g. Environmental"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="icon"/>
                                <field name="color" widget="color_picker"/>
                            </group>
                            <group>
                                <field name="sequence"/>
                                <field name="active" widget="boolean_toggle"/>
                                <field name="goal_count"/>
                            </group>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_esg_category" model="ir.actions.act_window">
            <field name="name">ESG Categories</field>
            <field name="res_model">esg.category</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first ESG Category
                </p>
                <p>Define the Environmental, Social, and Governance pillars for your organization.</p>
            </field>
        </record>

    </data>
</odoo>
