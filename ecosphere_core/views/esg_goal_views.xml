<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ════════════════════════════════════════════════════════════
             ESG GOAL — KANBAN
        ════════════════════════════════════════════════════════════ -->
        <record id="view_esg_goal_kanban" model="ir.ui.view">
            <field name="name">esg.goal.kanban</field>
            <field name="model">esg.goal</field>
            <field name="arch" type="xml">
                <kanban class="eco-kanban-goals" default_group_by="state">
                    <field name="name"/>
                    <field name="state"/>
                    <field name="progress"/>
                    <field name="category_id"/>
                    <field name="department_id"/>
                    <field name="deadline"/>
                    <field name="days_remaining"/>
                    <field name="color"/>
                    <field name="priority"/>
                    <templates>
                        <t t-name="card">
                            <div class="eco-goal-card">
                                <div class="eco-goal-header">
                                    <span t-attf-class="eco-category-pill eco-cat-#{record.category_id.raw_value}">
                                        <field name="category_id"/>
                                    </span>
                                    <field name="priority" widget="priority"/>
                                </div>
                                <div class="eco-goal-title">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="eco-goal-dept text-muted">
                                    <i class="fa fa-building-o"/> <field name="department_id"/>
                                </div>
                                <div class="eco-goal-progress-wrap">
                                    <div class="eco-goal-progress-bar" t-attf-style="width: #{record.progress.raw_value}%"/>
                                </div>
                                <div class="eco-goal-footer">
                                    <span class="eco-goal-pct"><field name="progress"/>%</span>
                                    <span t-attf-class="eco-deadline #{record.days_remaining.raw_value &lt; 7 ? 'eco-deadline-urgent' : ''}">
                                        <i class="fa fa-calendar"/> <field name="deadline"/>
                                    </span>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ════════════════════════════════════════════════════════════
             ESG GOAL — LIST
        ════════════════════════════════════════════════════════════ -->
        <record id="view_esg_goal_list" model="ir.ui.view">
            <field name="name">esg.goal.list</field>
            <field name="model">esg.goal</field>
            <field name="arch" type="xml">
                <list string="ESG Goals" decoration-success="state == 'achieved'" decoration-warning="state == 'at_risk'" decoration-danger="state == 'failed'" decoration-muted="state == 'cancelled'">
                    <field name="priority" widget="priority"/>
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="department_id"/>
                    <field name="responsible_id"/>
                    <field name="progress" widget="progressbar" options="{'editable': false}"/>
                    <field name="current_value" string="Current"/>
                    <field name="target_value" string="Target"/>
                    <field name="unit"/>
                    <field name="deadline"/>
                    <field name="days_remaining" string="Days Left"/>
                    <field name="state" widget="badge" decoration-success="state == 'achieved'" decoration-warning="state == 'at_risk'" decoration-danger="state == 'failed'"/>
                </list>
            </field>
        </record>

        <!-- ════════════════════════════════════════════════════════════
             ESG GOAL — FORM
        ════════════════════════════════════════════════════════════ -->
        <record id="view_esg_goal_form" model="ir.ui.view">
            <field name="name">esg.goal.form</field>
            <field name="model">esg.goal</field>
            <field name="arch" type="xml">
                <form string="ESG Goal">
                    <header>
                        <button name="action_activate" string="Activate" type="object"
                                class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_mark_achieved" string="Mark Achieved" type="object"
                                class="btn-success" invisible="state not in ('active', 'at_risk')"/>
                        <button name="action_mark_failed" string="Mark Failed" type="object"
                                invisible="state not in ('active', 'at_risk')"/>
                        <button name="action_cancel" string="Cancel" type="object"
                                invisible="state in ('achieved', 'failed', 'cancelled')"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                                invisible="state not in ('cancelled', 'failed')"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,active,at_risk,achieved"/>
                    </header>
                    <sheet>
                        <div class="eco-goal-progress-hero">
                            <div class="eco-goal-circle-wrap">
                                <div class="eco-goal-circle">
                                    <field name="progress" widget="gauge" options="{'max_value': 100, 'style': 'width:150px; height: 75px;'}"/>
                                </div>
                                <div class="eco-goal-pct-label">
                                    <field name="progress"/>% Complete
                                </div>
                            </div>
                        </div>

                        <div class="oe_title">
                            <label for="name" string="Goal Title"/>
                            <h1><field name="name" placeholder="Enter goal title…"/></h1>
                        </div>

                        <group>
                            <group string="Classification">
                                <field name="category_id"/>
                                <field name="department_id"/>
                                <field name="responsible_id"/>
                                <field name="priority" widget="priority"/>
                            </group>
                            <group string="Target &amp; Progress">
                                <field name="target_value"/>
                                <field name="current_value"/>
                                <field name="unit"/>
                                <field name="weight" string="Goal Weight (%)"/>
                            </group>
                        </group>

                        <group>
                            <group string="Timeline">
                                <field name="start_date"/>
                                <field name="deadline"/>
                                <field name="days_remaining" string="Days Remaining"/>
                            </group>
                        </group>

                        <group string="Description">
                            <field name="description" nolabel="1" widget="html"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- ════════════════════════════════════════════════════════════
             ESG GOAL — SEARCH
        ════════════════════════════════════════════════════════════ -->
        <record id="view_esg_goal_search" model="ir.ui.view">
            <field name="name">esg.goal.search</field>
            <field name="model">esg.goal</field>
            <field name="arch" type="xml">
                <search string="Search Goals">
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="category_id"/>
                    <field name="responsible_id"/>
                    <separator/>
                    <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                    <filter string="At Risk" name="at_risk" domain="[('state', '=', 'at_risk')]"/>
                    <filter string="Achieved" name="achieved" domain="[('state', '=', 'achieved')]"/>
                    <filter string="Overdue" name="overdue" domain="[('deadline', '&lt;', context_today().strftime('%Y-%m-%d')), ('state', 'not in', ['achieved', 'cancelled', 'failed'])]"/>
                    <filter string="My Goals" name="my_goals" domain="[('responsible_id', '=', uid)]"/>
                    <separator/>
                    <filter string="Environmental" name="env" domain="[('category_id.code', '=', 'E')]"/>
                    <filter string="Social" name="social" domain="[('category_id.code', '=', 'S')]"/>
                    <filter string="Governance" name="gov" domain="[('category_id.code', '=', 'G')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_dept" string="Department" context="{'group_by': 'department_id'}"/>
                        <filter name="group_cat" string="Category" context="{'group_by': 'category_id'}"/>
                        <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="group_deadline" string="Deadline" context="{'group_by': 'deadline:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_esg_goal" model="ir.actions.act_window">
            <field name="name">ESG Goals</field>
            <field name="res_model">esg.goal</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="search_view_id" ref="view_esg_goal_search"/>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create your first ESG Goal</p>
                <p>Set measurable targets for each department and ESG pillar.</p>
            </field>
        </record>

    </data>
</odoo>
